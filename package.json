{
  "name": "vue-h5-template",
  "version": "0.1.0",
  "description": "A Vue 3 + Vant 4 + Tailwind CSS H5 template.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vue-tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "dayjs": "1.11.21",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "vant": "4.9.24",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@iconify/json": "2.2.488",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "eslint": "10.5.0",
    "eslint-plugin-vue": "10.9.2",
    "only-allow": "1.2.2",
    "prettier": "3.8.4",
    "sass": "1.101.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "32.1.0",
    "vite": "8.0.16",
    "vite-plugin-mock-dev-server": "2.4.1",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.5",
    "@vue/tsconfig": "0.9.1",
    "globals": "17.6.0"
  }
}
